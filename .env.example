# Runtime persistence
#
# The current platform foundation uses a server-side JSON store for local
# development and early demos. In production, point this at a writable mounted
# volume. For a managed database migration, replace lib/platform-store.ts with a
# database adapter and keep the API route contracts stable.
PLATFORM_STORE_PATH=./data/platform-store.json
PLATFORM_UPLOADS_DIR=./data/uploads

# Optional sample listings for local demonstrations. Never enable this in a
# production environment; production should expose only provider-owned listings.
ENABLE_DEMO_PROVIDERS=true

# Public app URL for metadata, links, and deployment checks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails that may create or use admin accounts.
ADMIN_EMAILS=admin@example.com
